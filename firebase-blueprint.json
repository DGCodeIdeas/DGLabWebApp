{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform.",
      "type": "object",
      "properties": {
        "uuid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uuid", "email", "role"]
    },
    "MangaProject": {
      "title": "MangaProject",
      "description": "An uploaded EPUB project for MangaScript.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["uploading", "parsing", "ready", "packing", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "fileName": { "type": "string" },
        "downloadUrl": { "type": "string" }
      },
      "required": ["userId", "title", "status", "createdAt", "fileName"]
    },
    "MangaChapter": {
      "title": "MangaChapter",
      "description": "A chapter within a MangaProject.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["chapter", "prologue", "interlude", "epilogue", "other"] },
        "order": { "type": "integer" },
        "content": { "type": "string" },
        "translatedContent": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "ai_processing", "human_proofread", "approved", "packing"] },
        "entryName": { "type": "string" }
      },
      "required": ["projectId", "title", "type", "order", "content", "status", "entryName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/manga_projects/{projectId}": {
      "schema": "MangaProject",
      "description": "MangaScript projects."
    },
    "/manga_projects/{projectId}/chapters/{chapterId}": {
      "schema": "MangaChapter",
      "description": "Chapters within a MangaScript project."
    }
  }
}
