{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the DGLab platform.",
      "type": "object",
      "properties": {
        "uuid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "pending", "suspended"] },
        "mfaEnabled": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uuid", "email", "role"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "An organization or project container.",
      "type": "object",
      "properties": {
        "identifier": { "type": "string" },
        "domain": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "config": { "type": "object" }
      },
      "required": ["identifier", "status"]
    },
    "Job": {
      "title": "Job",
      "description": "A background processing task.",
      "type": "object",
      "properties": {
        "serviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed", "cancelled"] },
        "progress": { "type": "integer" },
        "message": { "type": "string" },
        "inputData": { "type": "object" },
        "outputData": { "type": "object" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serviceId", "status", "userId", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "A record of a system event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "eventType": { "type": "string" },
        "identifier": { "type": "string" },
        "statusCode": { "type": "integer" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "eventType", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Tenant configurations."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Processing jobs."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs."
    }
  }
}
